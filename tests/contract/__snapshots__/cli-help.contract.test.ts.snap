exports[`CLI help contract > help for "guard" is locked 1`] = `
"Usage: agentloop guard [options]

Check local drift, proof debt, and context-budget pressure

Options:
  --strict                  exit non-zero when Guard status is warn or fail
  --watch                   repeat Guard snapshots until interrupted or max
                            iterations is reached
  --interval-ms <ms>        watch interval in milliseconds (default: "2000")
  --max-iterations <count>  maximum watch iterations before exiting
  --write-report            write a local Markdown Guard report
  --out <path>              Guard report output path; requires --write-report
  --baseline <path>         compare current changed files with a Guard baseline
  --write-baseline <path>   write current changed files to a Guard baseline JSON
                            file
  --json                    print machine-readable output
  --compact                 with --json, omit full changed-file evidence and
                            include an expandable handle
  --redact-paths            redact local absolute paths in public output
  -h, --help                display help for command"
`;

