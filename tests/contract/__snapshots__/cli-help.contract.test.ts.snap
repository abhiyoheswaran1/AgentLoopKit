exports[`CLI help contract > help for "create-task" is locked 1`] = `
"Usage: agentloop create-task [options]

Create a task contract for an agentic engineering session

Options:
  --title <title>                task title
  --type <type>                  task type
  --from-projscan <path>         create a Baseframe task from a ProjScan
                                 assessment
  --out <path>                   output file path
  --problem <text>               problem statement
  --problem-statement <text>     problem statement
  --outcome <text>               desired outcome
  --desired-outcome <text>       desired outcome
  --constraint <text>            constraint; repeat or use newlines (default:
                                 [])
  --non-goal <text>              non-goal; repeat or use newlines (default: [])
  --assumption <text>            assumption; repeat or use newlines (default:
                                 [])
  --likely-file <path>           likely file or area; repeat or use newlines
                                 (default: [])
  --allow <path>                 Baseframe allowed path override; repeat or use
                                 newlines (default: [])
  --forbidden-file <path>        file or area not to touch; repeat or use
                                 newlines (default: [])
  --acceptance <text>            acceptance criterion; repeat or use newlines
                                 (default: [])
  --verify-command <command>     verification command; repeat or use newlines
                                 (default: [])
  --verification <command>       verification command; repeat or use newlines
                                 (default: [])
  --include-config-commands      copy configured test, lint, typecheck, and
                                 build commands into the task contract
  --post-verification <command>  post-verification gate; repeat or use newlines
                                 (default: [])
  --risk <text>                  risk note; repeat or use newlines (default: [])
  --risk-note <text>             risk note; repeat or use newlines (default: [])
  --rollback <text>              rollback notes
  --json                         print machine-readable output
  --redact-paths                 redact local absolute paths in public output
  -h, --help                     display help for command

Supported task types:
  - feature
  - bugfix
  - refactor
  - tests
  - test-generation
  - research
  - docs
  - release
  - security-review
  - dependency-upgrade
  - migration
"
`;

