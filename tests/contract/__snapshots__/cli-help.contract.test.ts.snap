  handoff [options]                Generate and write a deterministic reviewer
                                   handoff
  status [options]                 Show active task, latest verification, dirty
                                   files, and next action
  next [options]                   Show the next recommended loop action
  start [options]                  Brief a software agent with current task,
                                   evidence, risk, and context routing
  review-context [options]         Show one read-only reviewability context
                                   snapshot
  context                          Measure and package local AgentLoopKit
                                   context for software agents
  explain-diff [options]           Explain the current diff using local
                                   AgentLoopKit evidence
  resume-pack [options]            Generate a compact continuation brief from
                                   local AgentLoopKit evidence
  guard [options]                  Check local drift, proof debt, and
                                   context-budget pressure
  ready [options]                  Check whether local agent work is ready for
                                   review
  harden [options] [task]          Interrogate a task contract for unresolved
                                   soft spots before work starts.
  loop                             Create and inspect local low-token agent loop
                                   contracts
  check-gates [options]            Check whether task, verification, handoff,
                                   harness, policy, and git gates pass
  ship [options]                   Run the local review-readiness flow for
                                   agent-assisted changes
  prepare-pr [options]             Generate a PR description from local
                                   AgentLoopKit evidence
  runs [options]                   List local AgentLoopKit run ledger entries
  show-run [options] <id>          Show a local AgentLoopKit run ledger entry
  intent [options] <file>          Show which local AgentLoopKit runs touched a
                                   file
  maintainer-check [options]       Check whether an agent-assisted PR is ready
                                   for maintainer review
  report [options]                 Generate a local static HTML evidence report
  badge [options]                  Generate a local SVG evidence badge
  artifacts [options]              Show local AgentLoop evidence artifacts
                                   without writing files
  upgrade-harness [options]        Inspect existing AgentLoopKit harness
                                   guidance for upgrade gaps
  schemastore [options]            Print the SchemaStore catalog entry for
                                   agentloop.config.json
  github                           Import explicit local GitHub issue or PR
                                   metadata
  ci-summary [options]             Summarize CI context and AgentLoop evidence
  release-notes [options]          Generate deterministic release notes
  release-check [options]          Check local release readiness without
                                   publishing
  release-proof [options]          Check post-release evidence across public
                                   release channels
  npm-status [options]             Check npm registry catch-up status
  mcp-server                       Start the read-only AgentLoopKit MCP stdio
                                   server
  policy                           List or inspect local AgentLoopKit policies
  task                             List, inspect, update, complete, or archive
                                   task contracts
  install-agent [options] <agent>  Install agent-specific instruction files
  list-templates [options]         List available AgentLoopKit templates
  completion <shell>               Print shell completion scripts
  version [options]                Print CLI version
  help [command]                   display help for command"
