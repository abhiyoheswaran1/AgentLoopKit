exports[`CLI help contract > help for "artifacts" is locked 1`] = `
"Usage: agentloop artifacts [options]

Show local AgentLoop evidence artifacts without writing files

Options:
  --type <type>    filter by artifact type (task, verification, handoff,
                   ship-report, html-report, badge, ci-summary, release-notes,
                   run)
  --latest         print only the latest matching artifact(s)
  --stale          preview stale evidence candidates without deleting files
  --limit <count>  limit stale preview candidate output
  --json           print machine-readable output
  --redact-paths   accept common public-output redaction flag; artifact paths
                   are already repo-relative
  -h, --help       display help for command"
`;

exports[`CLI help contract > help for "badge" is locked 1`] = `
"Usage: agentloop badge [options]

Generate a local SVG evidence badge

Options:
  --source <source>   badge source: verification or gates (default:
                      "verification")
  --out <path>        output SVG path
  --strict            use strict gate status when source is gates
  --allow-soft-spots  treat unresolved blocking soft spots as a warning instead
                      of a failure
  --json              print machine-readable output
  --redact-paths      redact local absolute paths in public output
  -h, --help          display help for command"
`;

