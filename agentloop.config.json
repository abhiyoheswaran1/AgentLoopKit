{
  "$schema": "https://raw.githubusercontent.com/abhiyoheswaran1/AgentLoopKit/main/schema/agentloop.config.schema.json",
  "version": 1,
  "project": {
    "name": "agentloopkit",
    "type": "typescript-package",
    "packageManager": "pnpm"
  },
  "paths": {
    "root": ".",
    "agentloopDir": ".agentloop",
    "tasksDir": ".agentloop/tasks",
    "reportsDir": ".agentloop/reports",
    "handoffsDir": ".agentloop/handoffs"
  },
  "commands": {
    "test": "npx pnpm@10.12.1 test",
    "lint": "npx pnpm@10.12.1 lint",
    "typecheck": "npx pnpm@10.12.1 typecheck",
    "build": "npx pnpm@10.12.1 build",
    "format": "npx pnpm@10.12.1 format"
  },
  "safety": {
    "requireCleanWorkingTree": false,
    "warnOnDirtyWorkingTree": true,
    "protectEnvFiles": true,
    "protectMigrations": true,
    "protectLockfiles": false
  },
  "summary": {
    "includeDiffStats": true,
    "includeChangedFiles": true,
    "includeVerification": true,
    "includeRisks": true,
    "includeRollback": true
  }
}
